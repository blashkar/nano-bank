meta {
  name: Open Account
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/v1/accounts
  body: json
  auth: inherit
}

body:json {
  {
    "account_type": "credit_card"
  }
}

script:post-response {
  bru.setEnvVar("accountId", res.body.account_id);
}

settings {
  encodeUrl: true
  timeout: 0
}
