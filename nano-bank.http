# nano-bank API
# Run requests top to bottom in order — each one uses the response from the previous.
# Install extension first: code --install-extension humao.rest-client

@baseUrl = http://localhost:8081

# ─────────────────────────────────────────────────────────────
# 1. Health check
# ─────────────────────────────────────────────────────────────

GET {{baseUrl}}/health
Accept: application/json

###

# ─────────────────────────────────────────────────────────────
# 2. Register customer
#    The `password` is now hashed + stored, so step 3 can log in.
# ─────────────────────────────────────────────────────────────

# @name createCustomer
POST {{baseUrl}}/api/v1/customers
Content-Type: application/json

{
    "email": "jane.doe2@example.com",
    "phone_number": "4161234567",
    "first_name": "Jane",
    "last_name": "Doe",
    "date_of_birth": "1990-05-15",
    "sin": "123456789",
    "password": "securepass123"
}

###

# ─────────────────────────────────────────────────────────────
# 3. Login
#    Returns a short-lived access token + a refresh token (used in step 12).
# ─────────────────────────────────────────────────────────────

# @name login
POST {{baseUrl}}/api/v1/auth/login
Content-Type: application/json

{
    "email": "jane.doe2@example.com",
    "password": "securepass123"
}

###

@accessToken = {{login.response.body.access_token}}
@refreshToken = {{login.response.body.refresh_token}}

# ─────────────────────────────────────────────────────────────
# 3b. Get network service token (card rails / network plane)
#     The /cards/* endpoints authenticate the card NETWORK, not a
#     cardholder — so they use a service token, not the customer token.
# ─────────────────────────────────────────────────────────────

# @name serviceToken
POST {{baseUrl}}/api/v1/auth/service-token
Content-Type: application/json

{
    "client_secret": "nano-bank-visa-network-secret-change-me"
}

###

@serviceToken = {{serviceToken.response.body.access_token}}

# ─────────────────────────────────────────────────────────────
# 4. Open credit card account
#    customer comes from the token — no customer_id in the body.
#    Saves response so step 5 can read account_id from it.
# ─────────────────────────────────────────────────────────────

# @name openAccount
POST {{baseUrl}}/api/v1/accounts
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
    "account_type": "credit_card"
}

###

# ─────────────────────────────────────────────────────────────
# 5. Authorize purchase
#    Uses account_id from step 4. Saves response for step 6.
# ─────────────────────────────────────────────────────────────

# @name authorize
POST {{baseUrl}}/api/v1/cards/authorize
Content-Type: application/json
Authorization: Bearer {{serviceToken}}

{
    "account_id": "{{openAccount.response.body.account_id}}",
    "amount": 99.99,
    "merchant": "Tim Hortons"
}

###

# ─────────────────────────────────────────────────────────────
# 6. Capture authorization
#    Uses auth_id from step 5. Posts the double-entry journal entry.
# ─────────────────────────────────────────────────────────────

POST {{baseUrl}}/api/v1/cards/capture
Content-Type: application/json
Authorization: Bearer {{serviceToken}}

{
    "auth_id": "{{authorize.response.body.auth_id}}"
}

###

# ─────────────────────────────────────────────────────────────
# 7. Settle all captured purchases
#    Nets VISA_CLEARING against BANK_SETTLEMENT in one batch.
# ─────────────────────────────────────────────────────────────

POST {{baseUrl}}/api/v1/cards/settle
Content-Type: application/json
Authorization: Bearer {{serviceToken}}

{}

###

# ─────────────────────────────────────────────────────────────
# 8. List accounts for the authenticated customer
#    Returns Vec<AccountSummary> — scoped to the token, no query param.
# ─────────────────────────────────────────────────────────────

GET {{baseUrl}}/api/v1/accounts
Accept: application/json
Authorization: Bearer {{accessToken}}

###

# ─────────────────────────────────────────────────────────────
# 9. Get single account (full details)
#    Uses account_id from step 4. Returns AccountResponse.
# ─────────────────────────────────────────────────────────────

GET {{baseUrl}}/api/v1/accounts/{{openAccount.response.body.account_id}}
Accept: application/json
Authorization: Bearer {{accessToken}}

###

# ─────────────────────────────────────────────────────────────
# 10. Get balance with active holds
#     Uses account_id from step 4. Returns balance + holds[].
#     Run after step 5 (authorize) to see an open hold in holds[].
# ─────────────────────────────────────────────────────────────

GET {{baseUrl}}/api/v1/accounts/{{openAccount.response.body.account_id}}/balance
Accept: application/json
Authorization: Bearer {{accessToken}}

###

# ─────────────────────────────────────────────────────────────
# 11. Get customer profile
#     Customer comes from the token. Returns CustomerResponse.
# ─────────────────────────────────────────────────────────────

GET {{baseUrl}}/api/v1/customers/profile
Accept: application/json
Authorization: Bearer {{accessToken}}

###

# ─────────────────────────────────────────────────────────────
# 12. Refresh — exchange the refresh token for a new access token
#     The refresh token is single-use: this rotates it, so re-running
#     with the OLD refresh token returns 401. Use the new pair after.
# ─────────────────────────────────────────────────────────────

# @name refresh
POST {{baseUrl}}/api/v1/auth/refresh
Content-Type: application/json

{
    "refresh_token": "{{refreshToken}}"
}

###

@accessToken = {{refresh.response.body.access_token}}
@refreshToken = {{refresh.response.body.refresh_token}}

# ─────────────────────────────────────────────────────────────
# 13. Logout — terminate the session (revokes the refresh token)
#     Returns 204. Afterwards, step 12 with this session's refresh
#     token returns 401. The access token still works until it expires.
# ─────────────────────────────────────────────────────────────

POST {{baseUrl}}/api/v1/auth/logout
Authorization: Bearer {{accessToken}}

###
